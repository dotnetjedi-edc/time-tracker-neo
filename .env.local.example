# Clerk frontend publishable key (safe to expose in the browser)
# Get it from: https://dashboard.clerk.com → Your App → API Keys
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Clerk secret key (server-side only, never expose to the browser)
# Get it from: https://dashboard.clerk.com → Your App → API Keys
CLERK_SECRET_KEY=sk_test_...

# Turso database URL
# Get it from: https://app.turso.tech → Your DB → Connect → libsql URL
# Or via CLI: turso db show <db-name> --url
TURSO_DATABASE_URL=libsql://time-tracker-dev-<your-username>.turso.io

# Turso auth token
# Get it from: https://app.turso.tech → Your DB → Connect → Token
# Or via CLI: turso db tokens create <db-name>
# Optional only for local libSQL URLs such as file:, :memory:, http://127.0.0.1, or http://localhost
TURSO_AUTH_TOKEN=eyJ...
